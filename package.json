{
  "name": "super-reminder",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "expo": "~57.0.0",
    "expo-linking": "~57.0.0",
    "expo-notifications": "~57.0.0",
    "expo-router": "~57.0.0",
    "expo-secure-store": "~57.0.0",
    "expo-speech": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.1.1",
    "babel-preset-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": true
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^expo-notifications$": "<rootDir>/src/__mocks__/expo-notifications.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/expo-secure-store.ts",
      "^expo-speech$":        "<rootDir>/src/__mocks__/expo-speech.ts",
      "^expo-sqlite$":        "<rootDir>/src/__mocks__/expo-sqlite.ts"
    }
  },
  "private": true
}

{
  "name": "super-reminder",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "expo": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-intent-launcher": "~57.0.0",
    "expo-router": "~57.0.0",
    "expo-secure-store": "~57.0.0",
    "expo-speech": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.1.1",
    "babel-preset-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": true,
            "types": [
              "jest"
            ]
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@notifee/react-native$": "<rootDir>/src/__mocks__/@notifee/react-native.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/expo-secure-store.ts",
      "^expo-speech$": "<rootDir>/src/__mocks__/expo-speech.ts",
      "^expo-sqlite$": "<rootDir>/src/__mocks__/expo-sqlite.ts",
      "^react-native$": "<rootDir>/src/__mocks__/react-native.ts"
    }
  },
  "private": true
}

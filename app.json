{
  "expo": {
    "name": "Super Reminder",
    "slug": "super-reminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.superreminder.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Super Reminder uses text-to-speech to read your reminders aloud.",
        "NSSpeechRecognitionUsageDescription": "Super Reminder uses on-device speech synthesis only."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.superreminder.app",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF",
          "iosDisplayInForeground": true,
          "androidMode": "default"
        }
      ],
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "super-reminder",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57ad64c7-c507-4583-99fb-36cb7dd481bc"
      }
    }
  }
}
